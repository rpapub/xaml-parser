{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rpapub/xaml-parser/schemas/workflow.schema.json",
  "title": "Workflow DTO",
  "description": "Self-describing workflow with stable content-hash based IDs",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "schema_id": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URL"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (semver)"
    },
    "collected_at": {
      "type": "string",
      "format": "date-time",
      "description": "Collection timestamp (ISO 8601 UTC)"
    },
    "id": {
      "type": "string",
      "pattern": "^wf:sha256:[a-f0-9]{16}$",
      "description": "Stable workflow ID"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Workflow name"
    },
    "source": {
      "$ref": "#/$defs/SourceInfo",
      "description": "Source file information"
    },
    "metadata": {
      "$ref": "#/$defs/WorkflowMetadata",
      "description": "Workflow metadata"
    },
    "variables": {
      "type": "array",
      "items": {"$ref": "variable.schema.json"},
      "description": "Variable definitions"
    },
    "arguments": {
      "type": "array",
      "items": {"$ref": "argument.schema.json"},
      "description": "Argument definitions"
    },
    "dependencies": {
      "type": "array",
      "items": {"$ref": "#/$defs/DependencyDto"},
      "description": "Package dependencies"
    },
    "activities": {
      "type": "array",
      "items": {"$ref": "activity.schema.json"},
      "description": "Activity instances"
    },
    "edges": {
      "type": "array",
      "items": {"$ref": "edge.schema.json"},
      "description": "Control flow edges"
    },
    "invocations": {
      "type": "array",
      "items": {"$ref": "invocation.schema.json"},
      "description": "Workflow invocations"
    },
    "issues": {
      "type": "array",
      "items": {"$ref": "#/$defs/IssueDto"},
      "description": "Parsing/validation issues"
    }
  },
  "required": ["schema_id", "schema_version", "collected_at", "id", "name", "source", "metadata"],
  "additionalProperties": false,
  "$defs": {
    "SourceInfo": {
      "type": "object",
      "description": "Source file information",
      "properties": {
        "path": {
          "type": "string",
          "description": "Current relative path (POSIX format)"
        },
        "path_aliases": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Historical paths for rename tracking"
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Full SHA-256 hash of normalized XML content"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes"
        },
        "encoding": {
          "type": "string",
          "description": "Character encoding"
        }
      },
      "required": ["path", "hash"],
      "additionalProperties": false
    },
    "WorkflowMetadata": {
      "type": "object",
      "description": "Workflow-level metadata",
      "properties": {
        "project_name": {
          "type": ["string", "null"],
          "description": "Name of containing project"
        },
        "namespace": {
          "type": ["string", "null"],
          "description": ".NET namespace"
        },
        "expression_language": {
          "type": "string",
          "enum": ["VisualBasic", "CSharp"],
          "description": "Expression language"
        },
        "annotation": {
          "type": ["string", "null"],
          "description": "Root workflow annotation"
        },
        "display_name": {
          "type": ["string", "null"],
          "description": "User-visible workflow name"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Workflow description"
        }
      },
      "required": ["expression_language"],
      "additionalProperties": false
    },
    "DependencyDto": {
      "type": "object",
      "description": "Package dependency",
      "properties": {
        "package": {
          "type": "string",
          "minLength": 1,
          "description": "Package name"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Package version"
        }
      },
      "required": ["package", "version"],
      "additionalProperties": false
    },
    "IssueDto": {
      "type": "object",
      "description": "Parsing or validation issue",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "description": "Issue severity"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable message"
        },
        "path": {
          "type": ["string", "null"],
          "description": "Location path"
        },
        "code": {
          "type": ["string", "null"],
          "description": "Issue code for programmatic handling"
        }
      },
      "required": ["level", "message"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "schema_id": "https://rpax.io/schemas/xaml-workflow.json",
      "schema_version": "1.0.0",
      "collected_at": "2025-10-12T18:30:00Z",
      "id": "wf:sha256:abc123def456",
      "name": "Main",
      "source": {
        "path": "Main.xaml",
        "path_aliases": [],
        "hash": "sha256:abc123def456789012345678901234567890123456789012345678901234",
        "size_bytes": 15234,
        "encoding": "utf-8"
      },
      "metadata": {
        "project_name": "MyRPAProject",
        "namespace": "MyRPAProject",
        "expression_language": "VisualBasic",
        "annotation": "Main workflow for transaction processing",
        "display_name": "Main Workflow",
        "description": null
      },
      "variables": [],
      "arguments": [],
      "dependencies": [
        {"package": "UiPath.System.Activities", "version": "22.10.4"}
      ],
      "activities": [],
      "edges": [],
      "invocations": [],
      "issues": []
    }
  ]
}
