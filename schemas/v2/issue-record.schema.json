{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cpmf-uips-xaml.schemas/v2/issue-record.schema.json",
  "title": "Issue Record Payload",
  "description": "Parse error or validation issue for external consumption (v2 contract)",
  "type": "object",
  "properties": {
    "workflow_id": {
      "type": ["string", "null"],
      "description": "Associated workflow ID (null for project-level issues)",
      "pattern": "^wf:sha256:[a-f0-9]{64}$"
    },
    "activity_id": {
      "type": ["string", "null"],
      "description": "Associated activity ID (null for workflow-level issues)",
      "pattern": "^act:sha256:[a-f0-9]{64}$"
    },
    "severity": {
      "type": "string",
      "description": "Issue severity level",
      "enum": ["error", "warning", "info"]
    },
    "code": {
      "type": "string",
      "description": "Error or validation code"
    },
    "message": {
      "type": "string",
      "description": "Human-readable issue message"
    },
    "location": {
      "type": ["string", "null"],
      "description": "File path or location where issue occurred"
    }
  },
  "required": ["severity", "code", "message"]
}
